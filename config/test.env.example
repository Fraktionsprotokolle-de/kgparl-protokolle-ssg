# Test Environment Configuration
# Copy this file to test.env and fill in the values

# Typesense API Key (search-only key for browser)
TYPESENSE_API_KEY=your_search_api_key_here

# Typesense Admin Key (for indexing - keep secret!)
TYPESENSE_ADMIN_KEY=your_admin_api_key_here

# GitHub Token for fetching data
GITHUB_TOKEN=your_github_token_here
